generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== Auth =====

model User {
  id              String         @id @default(uuid()) @db.Uuid
  email           String         @unique @db.VarChar(255)
  passwordHash    String?        @map("password_hash") @db.VarChar(255)
  displayName     String?        @map("display_name") @db.VarChar(100)
  avatarUrl       String?        @map("avatar_url") @db.Text
  authProvider    String         @map("auth_provider") @default("local") @db.VarChar(20)
  authProviderId  String?        @map("auth_provider_id") @db.VarChar(255)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  series          Series[]
  refreshTokens   RefreshToken[]
  syncQueue       SyncQueue[]

  @@map("users")
}

model RefreshToken {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  tokenHash   String   @map("token_hash") @db.VarChar(255)
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ===== Series & Books =====

model Series {
  id          String   @id @default(uuid()) @db.Uuid
  ownerId     String   @map("owner_id") @db.Uuid
  title       String   @db.VarChar(500)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  books       Book[]
  characters  Character[]
  locations   Location[]
  organizations Organization[]
  rules       Rule[]
  terms       Term[]
  connections Connection[]
  authorStyle AuthorStyle?

  @@map("series")
}

model Book {
  id              String   @id @default(uuid()) @db.Uuid
  seriesId        String   @map("series_id") @db.Uuid
  title           String   @db.VarChar(500)
  subtitle        String?  @db.VarChar(500)
  genre           String?  @db.VarChar(100)
  tags            String[] @default([])
  annotationShort String?  @map("annotation_short") @db.Text
  annotationFull  String?  @map("annotation_full") @db.Text
  targetChars     Int?     @map("target_chars")
  status          String   @default("draft") @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  series          Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  chapters        Chapter[]
  ideas           Idea[]
  plotLines       PlotLine[]
  matrixCells     MatrixCell[]
  timelineEvents  TimelineEvent[]
  mindmapNodes    MindmapNode[]
  productionAssets ProductionAsset[]
  publications    Publication[]
  characterArcs   CharacterArc[]

  @@map("books")
}

// ===== Chapters & Scenes =====

model Chapter {
  id        String   @id @default(uuid()) @db.Uuid
  bookId    String   @map("book_id") @db.Uuid
  title     String   @db.VarChar(500)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  scenes    Scene[]

  @@map("chapters")
}

model Scene {
  id                String   @id @default(uuid()) @db.Uuid
  chapterId         String   @map("chapter_id") @db.Uuid
  title             String?  @db.VarChar(500)
  content           Json?    @default("{}")
  contentPlaintext  String?  @map("content_plaintext") @db.Text
  charCount         Int      @default(0) @map("char_count")
  wordCount         Int      @default(0) @map("word_count")
  status            String   @default("draft") @db.VarChar(20)
  sortOrder         Int      @default(0) @map("sort_order")
  tensionScore      Int?     @map("tension_score")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  chapter           Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  matrixCells       MatrixCell[]
  timelineEvents    TimelineEvent[]

  @@index([chapterId, sortOrder])
  @@map("scenes")
}

// ===== World Bible =====

model Character {
  id          String   @id @default(uuid()) @db.Uuid
  seriesId    String   @map("series_id") @db.Uuid
  scope       String   @default("series") @db.VarChar(20)
  bookId      String?  @map("book_id") @db.Uuid
  name        String   @db.VarChar(200)
  role        String?  @db.Text
  description String?  @db.Text
  nameVariants Json   @default("[]") @map("name_variants")
  status      String   @default("draft") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  series      Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  arcs        CharacterArc[]

  @@map("characters")
}

model Location {
  id                   String   @id @default(uuid()) @db.Uuid
  seriesId             String   @map("series_id") @db.Uuid
  scope                String   @default("series") @db.VarChar(20)
  bookId               String?  @map("book_id") @db.Uuid
  name                 String   @db.VarChar(200)
  category             String?  @db.VarChar(100)
  description          String?  @db.Text
  firstMentionSceneId  String?  @map("first_mention_scene_id") @db.Uuid
  status               String   @default("draft") @db.VarChar(20)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  series      Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@map("locations")
}

model Organization {
  id                   String   @id @default(uuid()) @db.Uuid
  seriesId             String   @map("series_id") @db.Uuid
  scope                String   @default("series") @db.VarChar(20)
  bookId               String?  @map("book_id") @db.Uuid
  name                 String   @db.VarChar(200)
  category             String?  @db.VarChar(100)
  description          String?  @db.Text
  firstMentionSceneId  String?  @map("first_mention_scene_id") @db.Uuid
  status               String   @default("draft") @db.VarChar(20)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  series      Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@map("organizations")
}

model Rule {
  id                   String   @id @default(uuid()) @db.Uuid
  seriesId             String   @map("series_id") @db.Uuid
  scope                String   @default("series") @db.VarChar(20)
  bookId               String?  @map("book_id") @db.Uuid
  name                 String   @db.VarChar(200)
  category             String?  @db.VarChar(100)
  formulation          String   @db.Text
  exceptions           String?  @db.Text
  firstMentionSceneId  String?  @map("first_mention_scene_id") @db.Uuid
  status               String   @default("draft") @db.VarChar(20)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  series      Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@map("rules")
}

model Term {
  id                   String   @id @default(uuid()) @db.Uuid
  seriesId             String   @map("series_id") @db.Uuid
  scope                String   @default("series") @db.VarChar(20)
  bookId               String?  @map("book_id") @db.Uuid
  term                 String   @db.VarChar(200)
  definition           String   @db.Text
  synonyms             String[] @default([])
  category             String?  @db.VarChar(100)
  firstMentionSceneId  String?  @map("first_mention_scene_id") @db.Uuid
  status               String   @default("draft") @db.VarChar(20)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  series      Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@map("terms")
}

model Connection {
  id         String   @id @default(uuid()) @db.Uuid
  seriesId   String   @map("series_id") @db.Uuid
  sourceType String   @map("source_type") @db.VarChar(50)
  sourceId   String   @map("source_id") @db.Uuid
  targetType String   @map("target_type") @db.VarChar(50)
  targetId   String   @map("target_id") @db.Uuid
  label      String?  @db.VarChar(200)
  createdAt  DateTime @default(now()) @map("created_at")

  series Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@map("connections")
}

model CharacterArc {
  id                    String   @id @default(uuid()) @db.Uuid
  characterId           String   @map("character_id") @db.Uuid
  bookId                String   @map("book_id") @db.Uuid
  sceneId               String?  @map("scene_id") @db.Uuid
  beatType              String   @map("beat_type") @db.VarChar(20)
  goal                  String?  @db.Text
  internalConflict      String?  @map("internal_conflict") @db.Text
  learned               String?  @db.Text
  relationToCharacterId String?  @map("relation_to_character_id") @db.Uuid
  sortOrder             Int      @default(0) @map("sort_order")
  createdAt             DateTime @default(now()) @map("created_at")

  character  Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  book       Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@map("character_arcs")
}

// ===== Planning =====

model PlotLine {
  id        String   @id @default(uuid()) @db.Uuid
  bookId    String   @map("book_id") @db.Uuid
  title     String   @db.VarChar(200)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  book      Book         @relation(fields: [bookId], references: [id], onDelete: Cascade)
  cells     MatrixCell[]

  @@map("plot_lines")
}

model MatrixCell {
  id             String   @id @default(uuid()) @db.Uuid
  bookId         String   @map("book_id") @db.Uuid
  plotLineId     String   @map("plot_line_id") @db.Uuid
  bitNumber      Int      @map("bit_number")
  bitDescription String?  @map("bit_description") @db.Text
  sceneId        String?  @map("scene_id") @db.Uuid
  status         String   @default("pending") @db.VarChar(20)
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")

  book     Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  plotLine PlotLine @relation(fields: [plotLineId], references: [id], onDelete: Cascade)
  scene    Scene?   @relation(fields: [sceneId], references: [id], onDelete: SetNull)

  @@map("matrix_cells")
}

model TimelineEvent {
  id           String   @id @default(uuid()) @db.Uuid
  bookId       String   @map("book_id") @db.Uuid
  title        String   @db.VarChar(500)
  description  String?  @db.Text
  eventDate    String?  @map("event_date") @db.VarChar(100)
  relativeTime String?  @map("relative_time") @db.VarChar(100)
  sceneId      String?  @map("scene_id") @db.Uuid
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  book  Book    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  scene Scene?  @relation(fields: [sceneId], references: [id], onDelete: SetNull)

  @@map("timeline_events")
}

model MindmapNode {
  id         String   @id @default(uuid()) @db.Uuid
  bookId     String   @map("book_id") @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String   @map("entity_id") @db.Uuid
  x          Float    @default(0)
  y          Float    @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@map("mindmap_nodes")
}

// ===== Ideas =====

model Idea {
  id        String   @id @default(uuid()) @db.Uuid
  bookId    String   @map("book_id") @db.Uuid
  title     String?  @db.VarChar(500)
  content   String?  @db.Text
  tags      String[] @default([])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@map("ideas")
}

// ===== Author Style =====

model AuthorStyle {
  id              String   @id @default(uuid()) @db.Uuid
  seriesId        String   @unique @map("series_id") @db.Uuid
  pov             String?  @db.Text
  tonality        String?  @db.Text
  punctuationRules Json   @default("[]") @map("punctuation_rules")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  series   Series          @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  stopList StopListEntry[]

  @@map("author_style")
}

model StopListEntry {
  id         String   @id @default(uuid()) @db.Uuid
  styleId    String   @map("style_id") @db.Uuid
  phrase     String   @db.VarChar(500)
  suggestion String?  @db.Text
  example    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  style AuthorStyle @relation(fields: [styleId], references: [id], onDelete: Cascade)

  @@map("stop_list_entries")
}

// ===== Production =====

model ProductionAsset {
  id        String   @id @default(uuid()) @db.Uuid
  bookId    String   @map("book_id") @db.Uuid
  assetType String   @map("asset_type") @db.VarChar(50)
  title     String?  @db.VarChar(500)
  fileUrl   String?  @map("file_url") @db.Text
  filePath  String?  @map("file_path") @db.VarChar(500)
  version   Int      @default(1)
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@map("production_assets")
}

// ===== Publication =====

model Publication {
  id            String    @id @default(uuid()) @db.Uuid
  bookId        String    @map("book_id") @db.Uuid
  platform      String    @db.VarChar(100)
  status        String    @default("draft") @db.VarChar(30)
  seoTitle      String?   @map("seo_title") @db.VarChar(500)
  seoDescription String? @map("seo_description") @db.Text
  seoKeywords   String[]  @default([]) @map("seo_keywords")
  notes         String?   @db.Text
  publishedAt   DateTime? @map("published_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@map("publications")
}

// ===== Versions =====

model Version {
  id         String   @id @default(uuid()) @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String   @map("entity_id") @db.Uuid
  snapshot   Json
  source     String   @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@map("versions")
}

// ===== Trash =====

model Trash {
  id         String   @id @default(uuid()) @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String   @map("entity_id") @db.Uuid
  entityData Json
  deletedBy  String?  @map("deleted_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  expiresAt  DateTime? @map("expires_at")

  @@map("trash")
}

// ===== Sync =====

model SyncQueue {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  entityType      String   @map("entity_type") @db.VarChar(50)
  entityId        String   @map("entity_id") @db.Uuid
  action          String   @db.VarChar(10)
  payload         Json
  clientTimestamp DateTime @map("client_timestamp")
  synced          Boolean  @default(false)
  syncedAt        DateTime? @map("synced_at")
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sync_queue")
}

model ChangeLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String   @map("entity_id") @db.Uuid
  action     String   @db.VarChar(10)
  diff       Json
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("change_log")
}
