generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== Auth =====

model User {
  id              String         @id @default(uuid()) @db.Uuid
  email           String         @unique @db.VarChar(255)
  passwordHash    String?        @map("password_hash") @db.VarChar(255)
  displayName     String?        @map("display_name") @db.VarChar(100)
  avatarUrl       String?        @map("avatar_url") @db.Text
  authProvider    String         @map("auth_provider") @default("local") @db.VarChar(20)
  authProviderId  String?        @map("auth_provider_id") @db.VarChar(255)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  projects        Project[]
  collaborators   Collaborator[]
  refreshTokens   RefreshToken[]
  comments        Comment[]
  versions        Version[]

  @@map("users")
}

model RefreshToken {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  tokenHash   String   @map("token_hash") @db.VarChar(255)
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ===== Project (top level, replaces Series) =====

model Project {
  id          String   @id @default(uuid()) @db.Uuid
  ownerId     String   @map("owner_id") @db.Uuid
  title       String   @db.VarChar(500)
  description String?  @db.Text
  settings    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  collaborators Collaborator[]
  books         Book[]
  codexEntries  CodexEntry[]
  relationships Relationship[]
  goals         Goal[]
  aiExpertRoles AIExpertRole[]

  @@map("projects")
}

// ===== Collaborator =====

model Collaborator {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String   @default("reader") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("collaborators")
}

// ===== Book =====

model Book {
  id              String   @id @default(uuid()) @db.Uuid
  projectId       String   @map("project_id") @db.Uuid
  title           String   @db.VarChar(500)
  subtitle        String?  @db.VarChar(500)
  genre           String?  @db.VarChar(100)
  tags            String[] @default([])
  annotationShort String?  @map("annotation_short") @db.Text
  annotationFull  String?  @map("annotation_full") @db.Text
  targetChars     Int?     @map("target_chars")
  status          String   @default("draft") @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapters       Chapter[]
  plotArcs       PlotArc[]
  outlineEntries OutlineEntry[]
  timelineEvents TimelineEvent[]

  @@map("books")
}

// ===== Chapter =====

model Chapter {
  id        String   @id @default(uuid()) @db.Uuid
  bookId    String   @map("book_id") @db.Uuid
  title     String   @db.VarChar(500)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  book   Book    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  scenes Scene[]

  @@map("chapters")
}

// ===== Scene =====

model Scene {
  id               String    @id @default(uuid()) @db.Uuid
  chapterId        String    @map("chapter_id") @db.Uuid
  title            String?   @db.VarChar(500)
  content          Json      @default("{}")
  status           String    @default("draft") @db.VarChar(20)
  sortOrder        Int       @default(0) @map("sort_order")
  povCharacterId   String?   @map("pov_character_id") @db.Uuid
  locationId       String?   @map("location_id") @db.Uuid
  wordCount        Int       @default(0) @map("word_count")
  charCount        Int       @default(0) @map("char_count")
  colorTag         String?   @map("color_tag") @db.VarChar(20)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  chapter          Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  beats            Beat[]
  entityLinks      SceneEntityLink[]
  plotCards        PlotCard[]
  comments         Comment[]
  timelineEvents   TimelineEvent[]

  @@index([chapterId, sortOrder])
  @@map("scenes")
}

// ===== Beat =====

model Beat {
  id          String   @id @default(uuid()) @db.Uuid
  sceneId     String   @map("scene_id") @db.Uuid
  title       String?  @db.VarChar(500)
  description String?  @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  scene Scene @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@map("beats")
}

// ===== CodexEntry (unified entity) =====

model CodexEntry {
  id                   String   @id @default(uuid()) @db.Uuid
  projectId            String   @map("project_id") @db.Uuid
  type                 String   @db.VarChar(50)
  name                 String   @db.VarChar(200)
  attributes           Json     @default("{}")
  scope                String   @default("series") @db.VarChar(20)
  status               String   @default("draft") @db.VarChar(20)
  firstMentionSceneId  String?  @map("first_mention_scene_id") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  project              Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceRelationships  Relationship[]   @relation("SourceEntry")
  targetRelationships  Relationship[]   @relation("TargetEntry")
  sceneLinks           SceneEntityLink[]

  @@index([projectId, type])
  @@map("codex_entries")
}

// ===== Relationship =====

model Relationship {
  id              String   @id @default(uuid()) @db.Uuid
  projectId       String   @map("project_id") @db.Uuid
  sourceEntryId   String   @map("source_entry_id") @db.Uuid
  targetEntryId   String   @map("target_entry_id") @db.Uuid
  label           String?  @db.VarChar(200)
  description     String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceEntry  CodexEntry  @relation("SourceEntry", fields: [sourceEntryId], references: [id], onDelete: Cascade)
  targetEntry  CodexEntry  @relation("TargetEntry", fields: [targetEntryId], references: [id], onDelete: Cascade)

  @@map("relationships")
}

// ===== SceneEntityLink =====

model SceneEntityLink {
  id        String   @id @default(uuid()) @db.Uuid
  sceneId   String   @map("scene_id") @db.Uuid
  entryId   String   @map("entry_id") @db.Uuid
  linkType  String   @map("link_type") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  scene Scene      @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  entry CodexEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@map("scene_entity_links")
}

// ===== PlotArc (Plot Board column) =====

model PlotArc {
  id        String   @id @default(uuid()) @db.Uuid
  bookId    String   @map("book_id") @db.Uuid
  title     String   @db.VarChar(200)
  color     String?  @db.VarChar(20)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  book  Book       @relation(fields: [bookId], references: [id], onDelete: Cascade)
  cards PlotCard[]

  @@map("plot_arcs")
}

// ===== PlotCard (Plot Board card) =====

model PlotCard {
  id          String   @id @default(uuid()) @db.Uuid
  arcId       String   @map("arc_id") @db.Uuid
  sceneId     String?  @map("scene_id") @db.Uuid
  title       String   @db.VarChar(500)
  description String?  @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  color       String?  @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")

  arc   PlotArc @relation(fields: [arcId], references: [id], onDelete: Cascade)
  scene Scene?  @relation(fields: [sceneId], references: [id], onDelete: SetNull)

  @@map("plot_cards")
}

// ===== OutlineEntry =====

model OutlineEntry {
  id            String   @id @default(uuid()) @db.Uuid
  bookId        String   @map("book_id") @db.Uuid
  chapterNumber Int?     @map("chapter_number")
  sceneNumber   Int?     @map("scene_number")
  summary       String   @db.Text
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@map("outline_entries")
}

// ===== TimelineEvent =====

model TimelineEvent {
  id           String   @id @default(uuid()) @db.Uuid
  bookId       String   @map("book_id") @db.Uuid
  title        String   @db.VarChar(500)
  description  String?  @db.Text
  eventDate    String?  @map("event_date") @db.VarChar(100)
  relativeTime String?  @map("relative_time") @db.VarChar(100)
  sceneId      String?  @map("scene_id") @db.Uuid
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  book  Book    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  scene Scene?  @relation(fields: [sceneId], references: [id], onDelete: SetNull)

  @@map("timeline_events")
}

// ===== Goal =====

model Goal {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  type         String   @db.VarChar(20)
  targetWords  Int      @map("target_words")
  deadline     DateTime?
  currentWords Int      @default(0) @map("current_words")
  streak       Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("goals")
}

// ===== Comment =====

model Comment {
  id        String   @id @default(uuid()) @db.Uuid
  sceneId   String?  @map("scene_id") @db.Uuid
  entryId   String?  @map("entry_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  content   String   @db.Text
  position  Json     @default("{}")
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  scene  Scene?  @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  author User    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("comments")
}

// ===== AIExpertRole =====

model AIExpertRole {
  id         String   @id @default(uuid()) @db.Uuid
  projectId  String   @map("project_id") @db.Uuid
  name       String   @db.VarChar(200)
  prompt     String   @db.Text
  isBuiltin  Boolean  @default(false) @map("is_builtin")
  quickActions Json  @default("[]") @map("quick_actions")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("ai_expert_roles")
}

// ===== Version =====

model Version {
  id         String   @id @default(uuid()) @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String   @map("entity_id") @db.Uuid
  snapshot   Json
  source     String   @db.VarChar(20)
  authorId   String?  @map("author_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@map("versions")
}

// ===== Trash =====

model Trash {
  id         String   @id @default(uuid()) @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String   @map("entity_id") @db.Uuid
  entityData Json
  deletedBy  String?  @map("deleted_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  expiresAt  DateTime? @map("expires_at")

  @@map("trash")
}
